{
  "extends": "../../packages/config-typescript/react.json",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@moonsnap/changelog": ["../../packages/changelog/src"],
      "@moonsnap/changelog/*": ["../../packages/changelog/src/*"],
      "@moonsnap/ui": ["../../packages/ui/src"],
      "@moonsnap/ui/*": ["../../packages/ui/src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx", "src/test/**/*"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
