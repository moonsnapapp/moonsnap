{
  "name": "moonsnap",
  "private": true,
  "license": "FSL-1.1-Apache-2.0",
  "version": "0.5.29",
  "packageManager": "bun@1.3.6",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "changelog:build": "node scripts/build-changelog-json.cjs",
    "changelog:release-notes": "node scripts/get-latest-release-notes.cjs",
    "dev": "bun run changelog:build && turbo dev",
    "dev:desktop": "bun run changelog:build && turbo dev --filter=@moonsnap/desktop",
    "dev:web": "bun run changelog:build && cd apps/web && bun run dev",
    "dev:all": "bun run changelog:build && concurrently -k -n desktop,web -c blue,magenta \"node scripts/run-with-msvc.cjs bun run --cwd apps/desktop tauri:dev:inner\" \"bun run --cwd apps/web dev\"",
    "setup:dev": "powershell -ExecutionPolicy Bypass -File scripts/setup-dev.ps1",
    "build": "bun run changelog:build && turbo build",
    "lint": "bun run changelog:build && turbo lint",
    "test": "bun run changelog:build && turbo test",
    "test:run": "bun run changelog:build && turbo test:run",
    "check:pinned-deps": "node scripts/check-pinned-dependencies.cjs",
    "typecheck": "bun run changelog:build && turbo typecheck",
    "tauri": "cd apps/desktop && tauri",
    "tauri:dev": "bun run changelog:build && node scripts/run-with-msvc.cjs bun run --cwd apps/desktop tauri:dev:inner",
    "tauri:build": "bun run changelog:build && node scripts/run-with-msvc.cjs bun run --cwd apps/desktop tauri:build",
    "version": "node scripts/build-changelog-json.cjs && node scripts/sync-versions.js && git add -A",
    "postversion": "git push && git push --tags",
    "release": "npm version patch",
    "release:minor": "npm version minor",
    "release:major": "npm version major",
    "release:beta": "npm version prerelease --preid=beta",
    "prepare": "husky"
  },
  "devDependencies": {
    "concurrently": "9.2.1",
    "husky": "9.1.7",
    "lint-staged": "15.5.2",
    "turbo": "2.9.8"
  },
  "lint-staged": {
    "apps/desktop/**/*.{ts,tsx}": [
      "eslint --fix --config apps/desktop/eslint.config.js"
    ],
    "apps/web/**/*.{ts,tsx}": [
      "eslint --fix --config apps/web/eslint.config.mjs"
    ],
    "packages/ui/**/*.{ts,tsx}": [
      "eslint --fix --config packages/ui/eslint.config.js"
    ],
    "apps/desktop/src-tauri/**/*.rs": [
      "cargo fmt --manifest-path apps/desktop/src-tauri/Cargo.toml --"
    ]
  },
  "dependencies": {
    "@uiw/react-color-hue": "2.10.1"
  }
}
