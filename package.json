{
  "name": "snapit",
  "private": true,
  "version": "0.4.14",
  "packageManager": "bun@1.3.6",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "turbo dev",
    "dev:desktop": "turbo dev --filter=@snapit/desktop",
    "dev:web": "turbo dev --filter=@snapit/web",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "test:run": "turbo test:run",
    "typecheck": "turbo typecheck",
    "tauri": "cd apps/desktop && tauri",
    "tauri:dev": "cd apps/desktop && tauri dev",
    "tauri:build": "cd apps/desktop && tauri build",
    "release": "npm version patch && git push && git push --tags",
    "prepare": "husky"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2"
  },
  "lint-staged": {
    "apps/desktop/**/*.{ts,tsx}": [
      "eslint --fix --config apps/desktop/eslint.config.js"
    ],
    "apps/web/**/*.{ts,tsx}": [
      "eslint --fix --config apps/web/eslint.config.mjs"
    ],
    "packages/ui/**/*.{ts,tsx}": [
      "eslint --fix --config packages/ui/eslint.config.js"
    ],
    "apps/desktop/src-tauri/**/*.rs": [
      "cargo fmt --manifest-path apps/desktop/src-tauri/Cargo.toml --"
    ]
  }
}
